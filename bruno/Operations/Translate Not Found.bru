meta {
  name: Translate Not Found
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/fhir/ConceptMap/$translate?url=http://nonexistent/ConceptMap&sourceCode=test&sourceSystem=http://test
  body: none
  auth: none
}

headers {
  Accept: application/fhir+json
}

assert {
  res.status: eq 200
  res.body.resourceType: eq Parameters
  res.body.parameter[0].name: eq result
  res.body.parameter[0].valueBoolean: eq false
}
