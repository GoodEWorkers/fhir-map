meta {
  name: Translate R4 Params (code/system)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/fhir/ConceptMap/$translate?url=http://example.org/fhir/ConceptMap/address-use&code=home&system=http://hl7.org/fhir/address-use
  body: none
  auth: none
}

headers {
  Accept: application/fhir+json
}

assert {
  res.status: eq 200
  res.body.resourceType: eq Parameters
  res.body.parameter[0].name: eq result
  res.body.parameter[0].valueBoolean: eq true
}
