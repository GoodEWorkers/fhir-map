            "lastUpdated": "2026-01-29T08:16:45.954+00:00"
          },
          "url": "http://example.org/fhir/StructureMap/hprim-to-hl7v2",
          "version": "1.0.0",
          "name": "HPRIMtoHL7v2",
          "title": "StructureMap to transform HPRIM to HL7v2",
          "status": "draft",
          "description": "StructureMap to transform HPRIM message into HL7v2 message.",
          "structure": [
            {
              "url": "http://example.org/fhir/StructureDefinition/HPRIM",
              "mode": "source"
            },
            {
              "url": "http://example.org/fhir/StructureDefinition/HL7v2",
              "mode": "target"
            }
          ],
          "group": [
            {
              "name": "main",
              "typeMode": "types",
              "input": [
                {
                  "name": "source",
                  "type": "HPRIM",
                  "mode": "source"
                },
                {
                  "name": "target",
                  "type": "HL7v2",
                  "mode": "target"
                }
              ],
              "rule": [
                {
                  "name": "h1",
                  "source": [
                    {
                      "context": "source",
                      "type": "string",
                      "element": "H",
                      "variable": "separator",
                      "condition": "$this.exists()"
                    }
                  ],
                  "target": [
                    {
                      "context": "target",
                      "element": "MSH-1",
                      "transform": "copy",
                      "parameter": [
                        {
                          "valueString": "^~\\&"
                        }
                      ]
                    }
                  ]
                },
                {
