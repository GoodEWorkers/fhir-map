                        {
                          "valueId": "sendingApp"
                        }
                      ]
                    }
                  ]
                },
                {
                  "name": "h76",
                  "source": [
                    {
                      "context": "source",
                      "type": "string",
                      "element": "H-6",
                      "variable": "msgType",
                      "condition": "$this.exists() and $this = 'ORU'"
                    }
                  ],
                  "target": [
                    {
                      "context": "target",
                      "element": "MSH-8",
                      "transform": "copy",
