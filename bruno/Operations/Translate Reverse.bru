meta {
  name: Translate Reverse (Target to Source)
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/fhir/ConceptMap/$translate?url=http://example.org/fhir/ConceptMap/address-use&targetCode=H&targetSystem=http://terminology.hl7.org/CodeSystem/v3-AddressUse
  body: none
  auth: none
}

headers {
  Accept: application/fhir+json
}

assert {
  res.status: eq 200
  res.body.resourceType: eq Parameters
  res.body.parameter[0].name: eq result
  res.body.parameter[0].valueBoolean: eq true
}
