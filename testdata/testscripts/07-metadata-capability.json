{
  "resourceType": "TestScript",
  "id": "fhir-map-07-metadata-capability",
  "url": "http://goodeworkers.github.io/fhir-map/testscripts/07-metadata-capability",
  "version": "1.0",
  "name": "FhirMapMetadataCapability",
  "title": "fhir-map: metadata — CapabilityStatement",
  "status": "active",
  "experimental": true,
  "date": "2026-05-27",
  "publisher": "fhir-map",
  "description": "GET /fhir/R5/metadata; assert HTTP 200 with a CapabilityStatement whose fhirVersion is 5.0.0 and whose first listed resource is ConceptMap.",
  "test": [
    {
      "id": "test-07",
      "name": "metadata returns an R5 CapabilityStatement listing ConceptMap",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "capabilities"
            },
            "description": "GET the server CapabilityStatement at /metadata",
            "encodeRequestUrl": true,
            "params": "/metadata",
            "responseId": "capability-response"
          }
        },
        {
          "assert": {
            "description": "HTTP status is 200 OK",
            "response": "okay",
            "warningOnly": false,
            "stopTestOnFail": true
          }
        },
        {
          "assert": {
            "description": "Response is a CapabilityStatement",
            "resource": "CapabilityStatement",
            "warningOnly": false,
            "stopTestOnFail": true
          }
        },
        {
          "assert": {
            "description": "fhirVersion is 5.0.0",
            "expression": "CapabilityStatement.fhirVersion",
            "operator": "equals",
            "value": "5.0.0",
            "warningOnly": false,
            "stopTestOnFail": true
          }
        },
        {
          "assert": {
            "description": "The first server resource is ConceptMap",
            "expression": "CapabilityStatement.rest.where(mode='server').resource.first().type",
            "operator": "equals",
            "value": "ConceptMap",
            "warningOnly": false,
            "stopTestOnFail": true
          }
        }
      ]
    }
  ]
}
